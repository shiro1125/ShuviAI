# API key for Google Gemini. Replace with the key obtained from Google AI Studio.
GEMINI_API_KEY=your_gemini_api_key_here

# Enable or disable text‑to‑speech output.
# Set to 'true' to allow the program to speak AI responses aloud; leave as 'false'
# to print responses to the console only.
USE_TTS=false

# Optional configuration for alternate TTS providers (currently unused).
# TTS_PROVIDER=elevenlabs
# TTS_API_KEY=your_external_tts_api_key_here
# TTS_VOICE_ID=your_voice_id_here