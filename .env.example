# API key for Google Gemini. Replace with the key obtained from Google AI Studio
# or Google Cloud console.  This key is required for the AI integration to work.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: specify a Gemini model to use.  The default is 'models/gemini-pro'.
# Other models may include 'gemini-pro', 'gemini-pro-vision', etc.
# GEMINI_MODEL=models/gemini-pro

# Enable or disable text‑to‑speech output.  When set to 'true', the program
# will speak AI responses aloud using the default system voice.  If set to
# 'false', responses are printed to the console only.
USE_TTS=false

# Optional configuration for alternate TTS providers (currently unused).  If you
# choose to integrate with an external service (e.g. ElevenLabs), place
# credentials here.
# TTS_PROVIDER=elevenlabs
# TTS_API_KEY=your_external_tts_api_key_here
# TTS_VOICE_ID=your_voice_id_here